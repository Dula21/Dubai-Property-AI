# Dubai Property AI - Environment Variables Template
# Replace the placeholders below with your actual keys.
# DO NOT upload your actual .env file to GitHub.

# Groq Cloud API Key (Get it from https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face Token (Optional, if using private models)
HF_TOKEN=your_hugging_face_token_here

# App Configuration
DEBUG=True
MODEL_NAME=llama-3.1-70b-versatile
