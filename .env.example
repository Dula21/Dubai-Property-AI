# =================================================================
# DUBAI PROPERTY INTELLIGENCE - ENVIRONMENT VARIABLES TEMPLATE
# =================================================================
# Instructions:
# 1. Copy this file and rename it to ".env"
# 2. Add your private API keys to the new ".env" file.
# 3. Ensure ".env" is listed in your .gitignore to prevent data leaks.
# =================================================================

# GROQ API KEY
# Obtain your key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# LLM CONFIGURATION
MODEL_NAME=llama-3.1-70b-versatile
TEMPERATURE=0.2

# OPTIONAL: GRADIO SETTINGS
# Set to 1 to enable debug mode during development
GRADIO_DEBUG=0
